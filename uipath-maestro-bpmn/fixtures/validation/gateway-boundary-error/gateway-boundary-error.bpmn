<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:uipath="http://uipath.org/schema/bpmn" id="Definitions_GatewayBoundary" targetNamespace="http://uipath.com/synthetic/maestro-bpmn/gateway">
  <bpmn:error id="Error_ServiceUnavailable" name="ServiceUnavailable" errorCode="SERVICE_UNAVAILABLE" />
  <bpmn:process id="Process_GatewayBoundary" name="Gateway Boundary Error" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:input id="Var_RequestType" name="requestType" type="string" elementId="Start_Manual" />
        <uipath:inputOutput id="Var_RetryCount" name="retryCount" type="integer" default="0" />
        <uipath:output id="Var_Result" name="result" type="string" />
      </uipath:variables>
      <uipath:bindings version="v1">
        <uipath:binding id="Binding_ReviewProcess" name="Review Process" type="process" elementId="Task_StartReview" resource="ReviewProcess" resourceSubType="process" resourceKey="review-process" />
      </uipath:bindings>
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_Manual" name="Start">
      <bpmn:extensionElements>
        <uipath:entryPointId value="Entry_GatewayBoundary" />
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_To_Gateway</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_RequestType" name="Request Type" default="Flow_Gateway_To_Archive">
      <bpmn:incoming>Flow_Start_To_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Gateway_To_Review</bpmn:outgoing>
      <bpmn:outgoing>Flow_Gateway_To_Archive</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_StartReview" name="Start Review">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartJob" version="v1" />
          <uipath:context>
            <uipath:input name="process" type="resource" value="=bindings.Binding_ReviewProcess" />
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"requestType":"=vars.Var_RequestType"}]]></uipath:input>
          <uipath:output name="JobState" type="string" var="Var_Result" source="state" />
        </uipath:activity>
        <uipath:retry maxRetryCount="2" retryBackoff="PT30S" retryAllErrors="false">
          <uipath:errorDefinition errorRef="Error_ServiceUnavailable" />
        </uipath:retry>
        <uipath:errorMapping version="v1">
          <uipath:error id="Mapped_ServiceUnavailable" errorRef="Error_ServiceUnavailable" priority="1" condition="=vars.error.code == &quot;SERVICE_UNAVAILABLE&quot;" detail="Service unavailable" retryable="true" />
        </uipath:errorMapping>
        <uipath:tags>
          <uipath:tag key="fixture">gateway-boundary-error</uipath:tag>
        </uipath:tags>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Gateway_To_Review</bpmn:incoming>
      <bpmn:outgoing>Flow_Review_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:task id="Task_Archive" name="Archive">
      <bpmn:incoming>Flow_Gateway_To_Archive</bpmn:incoming>
      <bpmn:outgoing>Flow_Archive_To_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:boundaryEvent id="Boundary_ServiceUnavailable" name="Service Unavailable" attachedToRef="Task_StartReview">
      <bpmn:outgoing>Flow_Boundary_To_Terminate</bpmn:outgoing>
      <bpmn:errorEventDefinition id="ErrorDef_Boundary_ServiceUnavailable" errorRef="Error_ServiceUnavailable" />
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="End_Complete" name="Complete">
      <bpmn:incoming>Flow_Review_To_End</bpmn:incoming>
      <bpmn:incoming>Flow_Archive_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Terminated" name="Terminated">
      <bpmn:incoming>Flow_Boundary_To_Terminate</bpmn:incoming>
      <bpmn:terminateEventDefinition id="TerminateDef_GatewayBoundary" />
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_Gateway" sourceRef="Start_Manual" targetRef="Gateway_RequestType" />
    <bpmn:sequenceFlow id="Flow_Gateway_To_Review" sourceRef="Gateway_RequestType" targetRef="Task_StartReview">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">=vars.Var_RequestType == "review"</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Gateway_To_Archive" sourceRef="Gateway_RequestType" targetRef="Task_Archive" />
    <bpmn:sequenceFlow id="Flow_Review_To_End" sourceRef="Task_StartReview" targetRef="End_Complete" />
    <bpmn:sequenceFlow id="Flow_Archive_To_End" sourceRef="Task_Archive" targetRef="End_Complete" />
    <bpmn:sequenceFlow id="Flow_Boundary_To_Terminate" sourceRef="Boundary_ServiceUnavailable" targetRef="End_Terminated" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_GatewayBoundary">
    <bpmndi:BPMNPlane id="Plane_GatewayBoundary" bpmnElement="Process_GatewayBoundary">
      <bpmndi:BPMNShape id="Shape_Start_Manual" bpmnElement="Start_Manual"><dc:Bounds x="100" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Gateway_RequestType" bpmnElement="Gateway_RequestType" isMarkerVisible="true"><dc:Bounds x="200" y="153" width="50" height="50" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_StartReview" bpmnElement="Task_StartReview"><dc:Bounds x="320" y="96" width="140" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_Archive" bpmnElement="Task_Archive"><dc:Bounds x="320" y="230" width="140" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Boundary_ServiceUnavailable" bpmnElement="Boundary_ServiceUnavailable"><dc:Bounds x="430" y="158" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Complete" bpmnElement="End_Complete"><dc:Bounds x="540" y="160" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_Terminated" bpmnElement="End_Terminated"><dc:Bounds x="540" y="72" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_Gateway" bpmnElement="Flow_Start_To_Gateway"><di:waypoint x="136" y="178" /><di:waypoint x="200" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Gateway_To_Review" bpmnElement="Flow_Gateway_To_Review"><di:waypoint x="225" y="153" /><di:waypoint x="225" y="136" /><di:waypoint x="320" y="136" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Gateway_To_Archive" bpmnElement="Flow_Gateway_To_Archive"><di:waypoint x="225" y="203" /><di:waypoint x="225" y="270" /><di:waypoint x="320" y="270" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Review_To_End" bpmnElement="Flow_Review_To_End"><di:waypoint x="460" y="136" /><di:waypoint x="500" y="136" /><di:waypoint x="500" y="178" /><di:waypoint x="540" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Archive_To_End" bpmnElement="Flow_Archive_To_End"><di:waypoint x="460" y="270" /><di:waypoint x="500" y="270" /><di:waypoint x="500" y="178" /><di:waypoint x="540" y="178" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Boundary_To_Terminate" bpmnElement="Flow_Boundary_To_Terminate"><di:waypoint x="448" y="158" /><di:waypoint x="448" y="90" /><di:waypoint x="540" y="90" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
