<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:uipath="http://uipath.org/schema/bpmn" id="Definitions_IntegrationService" targetNamespace="http://uipath.com/synthetic/maestro-bpmn/integration-service">
  <bpmn:process id="Process_IntegrationService" name="Integration Service Enriched" isExecutable="true">
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:inputOutput id="Var_RecordId" name="recordId" type="string" elementId="Start_RecordCreated" />
        <uipath:output id="Var_TicketId" name="ticketId" type="string" />
      </uipath:variables>
      <uipath:bindings version="v1">
        <uipath:binding id="Binding_ServiceDeskConnection" name="Service Desk Connection" type="connection" elementId="Task_CreateTicket" resource="ServiceDesk" resourceSubType="connection" resourceKey="service-desk-connection" />
        <uipath:binding id="Binding_RecordCreatedTrigger" name="Record Created Trigger" type="eventTrigger" elementId="Start_RecordCreated" resource="ServiceDesk.RecordCreated" resourceSubType="eventTrigger" resourceKey="record-created-trigger" />
        <uipath:binding id="Binding_RecordObjectProperty" name="Record Object Property" type="property" elementId="Start_RecordCreated" resource="RecordObject" resourceSubType="property" resourceKey="record-object-property" propertyAttribute="objectName" />
      </uipath:bindings>
    </bpmn:extensionElements>
    <bpmn:startEvent id="Start_RecordCreated" name="Record Created">
      <bpmn:extensionElements>
        <uipath:entryPointId value="Entry_RecordCreated" />
        <uipath:event version="v1">
          <uipath:type value="Intsvc.EventTrigger" version="v1" />
          <uipath:context>
            <uipath:input name="connection" type="resource" value="=bindings.Binding_ServiceDeskConnection" />
            <uipath:input name="trigger" type="resource" value="=bindings.Binding_RecordCreatedTrigger" />
            <uipath:input name="object" type="resource" value="=bindings.Binding_RecordObjectProperty" />
            <uipath:input name="connectorKey" type="string" value="service-desk" />
            <uipath:input name="eventName" type="string" value="record-created" />
          </uipath:context>
          <uipath:output name="RecordId" type="string" var="Var_RecordId" source="id" />
        </uipath:event>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_Start_To_CreateTicket</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_CreateTicket" name="Create Ticket">
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Intsvc.ActivityExecution" version="v1" />
          <uipath:context>
            <uipath:input name="connection" type="resource" value="=bindings.Binding_ServiceDeskConnection" />
            <uipath:input name="connectorKey" type="string" value="service-desk" />
            <uipath:input name="activity" type="string" value="create-ticket" />
            <uipath:input name="operation" type="string" value="tickets.create" />
          </uipath:context>
          <uipath:input name="TicketBody" type="json" target="bodyField"><![CDATA[{"sourceRecordId":"=vars.Var_RecordId","summary":"Synthetic validation ticket"}]]></uipath:input>
          <uipath:inputSchema><![CDATA[{"type":"object","properties":{"sourceRecordId":{"type":"string"},"summary":{"type":"string"}}}]]></uipath:inputSchema>
          <uipath:output name="TicketId" type="string" var="Var_TicketId" source="id" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Start_To_CreateTicket</bpmn:incoming>
      <bpmn:outgoing>Flow_CreateTicket_To_End</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_TicketCreated" name="Ticket Created">
      <bpmn:incoming>Flow_CreateTicket_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_To_CreateTicket" sourceRef="Start_RecordCreated" targetRef="Task_CreateTicket" />
    <bpmn:sequenceFlow id="Flow_CreateTicket_To_End" sourceRef="Task_CreateTicket" targetRef="End_TicketCreated" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_IntegrationService">
    <bpmndi:BPMNPlane id="Plane_IntegrationService" bpmnElement="Process_IntegrationService">
      <bpmndi:BPMNShape id="Shape_Start_RecordCreated" bpmnElement="Start_RecordCreated"><dc:Bounds x="100" y="120" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CreateTicket" bpmnElement="Task_CreateTicket"><dc:Bounds x="220" y="98" width="140" height="80" /></bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_End_TicketCreated" bpmnElement="End_TicketCreated"><dc:Bounds x="440" y="120" width="36" height="36" /></bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_Start_To_CreateTicket" bpmnElement="Flow_Start_To_CreateTicket"><di:waypoint x="136" y="138" /><di:waypoint x="220" y="138" /></bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CreateTicket_To_End" bpmnElement="Flow_CreateTicket_To_End"><di:waypoint x="360" y="138" /><di:waypoint x="440" y="138" /></bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
